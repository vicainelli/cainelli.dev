---
import { Mail, Send } from "@lucide/astro";
// biome-ignore lint/correctness/noUnusedImports: used in template
import ContentWrapper from "@/components/ContentWrapper.astro";
// biome-ignore lint/correctness/noUnusedImports: used in template
import Breadcrumbs from "@/components/molecules/Breadcrumbs.astro";
// biome-ignore lint/correctness/noUnusedImports: used in template
import Layout from "@/layouts/Layout.astro";

// biome-ignore lint/correctness/noUnusedVariables: used in template
const BREADCRUMBS = [{ title: "Home", url: "/" }, { title: "Contact" }];

// biome-ignore lint/correctness/noUnusedVariables: used in template
const PRIMARY_CONTACTS = [
	{
		name: "Email",
		url: "mailto:vicainelli@gmail.com",
		icon: Mail,
		description: "Best for detailed conversations",
	},
	{
		name: "Telegram",
		url: "https://t.me/vicainelli",
		icon: Send,
		description: "Quick messages and casual chats",
	},
];
---

<Layout title="Contact - Vinicius Cainelli" description="Get in touch about frontend opportunities, collaborations, or just to say hi.">
  <ContentWrapper>
      <main class="mt-20">
      <Breadcrumbs items={BREADCRUMBS} />

      <h1 class="mb-8">Let's connect</h1>

      <section class="mt-12">
          <p class="text-balance mb-8">
              I'm always interested in hearing about new opportunities, frontend collaborations, or just chatting about design systems and developer experience. Whether you have a project in mind or just want to say hi, I'd love to hear from you.
          </p>

          <h2 class="font-semibold mb-6 uppercase text-xl tracking-widest">Direct Contact</h2>
          <p class="text-balance mb-6">I usually reply within one business day. Email and Telegram are the fastest ways to reach me.</p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-12">
              {PRIMARY_CONTACTS.map((contact) => (
                  <a
                      href={contact.url}
                      class="block p-6 rounded-md border-2 border-accent hover:bg-accent hover:text-accent-text transition-all duration-300 group"
                  >
                      <div class="flex items-start gap-4">
                          <div class="flex-shrink-0 mt-1">
                              <contact.icon size={24} />
                          </div>
                          <div>
                              <h3 class="font-semibold text-lg mb-1">{contact.name}</h3>
                              <p class="text-sm text-muted group-hover:text-accent-text/80">{contact.description}</p>
                          </div>
                      </div>
                  </a>
              ))}
          </div>
      </section>
    </main>
  </ContentWrapper>
</Layout>
