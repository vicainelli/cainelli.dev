---
import ContentWrapper from "@/components/ContentWrapper.astro";
import PostList from "@/components/PostList.astro";
import Layout from "@/layouts/Layout.astro";
import { cn } from "@/lib/utils";
import { getNonDraftPosts } from "@/lib/posts";

// biome-ignore lint/correctness/noUnusedVariables: used in template
const recentPosts = await getNonDraftPosts({ limit: 5 });

// biome-ignore lint/correctness/noUnusedVariables: used in template
const WORK_EXPERIENCE = [
	{
		company: "IKEA",
		description:
			"Building the IKEA Family rewards experience for customers and co-workers across multiple markets.",
		current: true,
		url: "/work/ikea",
	},
	{
		company: "JustEat Takeaway",
		description:
			"Helped build a Vue design system used by 10+ squads so teams could ship faster with consistent UI.",
		current: false,
		url: "/work/justeat-takeaway",
	},
	{
		company: "VIVO / Telefónica",
		description:
			"Rebuilt the self-service app in Vue with reusable components and solid tests, reducing support load.",
		current: false,
		url: "/work/vivo-telefonica",
	},
];
---

<Layout title="Vinicius Cainelli - Staff Product Engineer">
  <ContentWrapper>
    <main class="my-20">
      <section>
        <div class="">
            <div data-testid="vinicius-cainelli" class="flex items-center mb-8 gap-4">
                <div class="rounded-full border w-16 h-16 overflow-hidden">
                    <a title="" href="/me">
                        <img
                            src="/assets/images/vinicius-cainelli-doodle.png"
                            width="64" height="64"
                            class="rounded-full" alt="Vinicius Cainelli avatar">
                    </a>
                </div>
                <h1 class="m-0! p-0 leading-none">Vinicius Cainelli</h1>
            </div>

            <p class="leading-relaxed">
                I am a software engineer focused on frontend and UI. I like building products that are clear, useful, and pleasant to use. <br>
                Based in the Netherlands, I currently work on the IKEA Family experience at <a class="" href="./work/ikea">IKEA</a>.
            </p>
        </div>
      </section>

      <section  class="my-8">
          <div>
              <div class="flex justify-between border-b  py-2 mb-4 items-center">
                  <div><h2 class="text-2xl">Work</h2></div>
                  <div>
                      <a class="" href="/work">view all</a>
                  </div>
              </div>
          <div class="my-2 grid grid-cols-1 sm:grid-cols-2 gap-6">
              {WORK_EXPERIENCE.map((work) => (
              <a href={work.url} class={cn(
                // Position
                // Layout
                "p-4 rounded-md",

                // Styling
                "border  hover:bg-",
                // Dark mode
                // " dark:border-stone-500 dark:hover:bg-stone-700",

                // Other
                "transition-all duration-400 ease-in-out",
                "group",
                `${work.current ? 'sm:col-span-2' : ''}`,
              )}>
                  <h3 class="font-semibold mb-1 transition-colors ease-out">{work.company}</h3>
                  <p class=" text-sm">{work.description}</p>
              </a>
              ))}
          </div>
          </div>
      </section>

      {recentPosts ?? (<section class="my-8">
          <div>
              <div class="flex justify-between border-b  py-2 mb-4 items-center">
                  <div><h2 class="text-2xl">Recent Writing</h2></div>
                  <div>
                      <a class="" href="/me/writing">view all</a>
                  </div>
              </div>
              <PostList posts={recentPosts} />
          </div>
      </section>)}

    </main>
  </ContentWrapper>
</Layout>
