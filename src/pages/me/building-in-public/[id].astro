---
import { type CollectionEntry, getCollection, render } from "astro:content";
import ExternalLink from "@/components/atoms/ExternalLink.astro";
import ContentWrapper from "@/components/ContentWrapper.astro";
import AuthorCard from "@/components/molecules/AuthorCard.astro";
import Breadcrumbs from "@/components/molecules/Breadcrumbs.astro";
import Layout from "@/layouts/Layout.astro";

interface Props {
	post: CollectionEntry<"buildingInPublic">;
}

export async function getStaticPaths() {
	const posts = await getCollection("buildingInPublic");
	return posts.map((post) => ({
		params: { id: post.id },
		props: { post },
	}));
}
const { post } = Astro.props;
const { Content } = await render(post);

const BREADCRUMBS = [
	{ title: "Home", url: "/" },
	{ title: "Me", url: "/me" },
	{ title: "Building in Public", url: "/me/building-in-public" },
	{ title: post.data.title },
];
---
<Layout
	title={`${post.data.title} / Building in Public / Vinicius Cainelli - Staff Product Engineer`}
	description={post.data.description}
>
	<ContentWrapper>
		<main class="my-20">
			<Breadcrumbs items={BREADCRUMBS} />
			<article class="writing">
				<AuthorCard postData={post.data} />

				<hr class="my-4 border" />

				<Content components={{ a: ExternalLink }} />
			</article>
		</main>
	</ContentWrapper>
</Layout>
